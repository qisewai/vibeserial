{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeSerial",
  "version": "0.1.0",
  "identifier": "com.vibeserial.app",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "cd ../ui && npm run dev",
    "beforeBuildCommand": "cd ../ui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "VibeSerial",
        "width": 1280,
        "height": 840,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
